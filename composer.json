{
    "name": "sajidwarner/laravel-device-detector",
    "description": "LaraTrack — Laravel package for browser detection, device detection, IP geolocation, bot detection, Tor detection and platform detection",
    "keywords": [
        "laravel",
        "laratrack",
        "device-detector",
        "device-detection",
        "browser-detection",
        "browser-detector",
        "user-agent",
        "user-agent-parser",
        "user-agent-detector",
        "mobile-detection",
        "mobile-detector",
        "robot-detection",
        "bot-detection",
        "tor-detection",
        "ip-geolocation",
        "geolocation",
        "platform-detection",
        "tablet-detection",
        "client-hints",
        "sec-ch-ua",
        "laravel-package",
        "php"
    ],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Syed Sajid Akram",
            "email": "bestcyberking@gmail.com",
            "homepage": "https://github.com/sajidwarner",
            "role": "Developer"
        }
    ],
    "credits": [
        "Package development assisted by Claude.ai (Anthropic)"
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "illuminate/cache": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0|^12.0",
        "mockery/mockery": "^1.5"
    },
    "autoload": {
        "psr-4": {
            "SajidWarner\\LaraTrack\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SajidWarner\\LaraTrack\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage"
    },
    "extra": {
        "laravel": {
            "providers": [
                "SajidWarner\\LaraTrack\\LaraTrackServiceProvider"
            ],
            "aliases": {
                "LaraTrack": "SajidWarner\\LaraTrack\\Facades\\LaraTrack"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
